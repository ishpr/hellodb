{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": true,
    "lib": ["ES2022"],
    "types": ["./worker-configuration.d.ts"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
